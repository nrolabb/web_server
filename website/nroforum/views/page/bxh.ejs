<%-include("../partials/meta.ejs")%>

  <body>
    <%
    function shortenPower(number) {
      return number.toString().replace(/\B(?=(\d{3})+(?!\d))/g, ",")
    }
    allUser.sort((a, b) => (b.power + b.pet_power) - (a.power + a.pet_power))
    %>
    <%-include("../partials/head.ejs")%>
      <section id="bxh" class="section container section--bxh bxh scrollFrame">
        <div class="section__content_rank">
          <div class="inner-rank inner-rank--bxh">
              <div class="row">
                <div class="col-12 col-mobile-12">
                  <div class="effect">
                    <div class="layer">
                      <div class="para-laplanh desktop laplanh"><img src="./assets/images/effect.png" class="lazyloaded">
                      </div>
                    </div> <img src="./assets/images/character.png" class="character desktop lazyloaded">
                    <div class="layer layer__right--bottom">
                      <div class="para-nui desktop nui"><img src="./assets/images/nui.png" class="lazyloaded"></div>
                    </div>
                  </div>
                  <div id="block-ranking" class="effect__rank">
                    <div id="blockHomeRank" class="rank">
                      <div class="rank_filter"><select name="server" data-loadrank-handle="server" id="serverSelect">
                          <option value="0">Super</option>
                        </select></div>
                      <div id="blockHomeRankTab" class="rank">
                        <ul class="rank_tab">
                          <li><a href="/bxh?type=0" rel="rank_type=getUserRanking" class="rank_tab__item<%-type==0?'_active':''%>">
                              Top Power
                            </a></li>
                          <li><a href="/bxh?type=1" rel="rank_type=getUserPowerRanking" class="rank_tab__item<%-type==1?'_active':''%>">
                              Top Đại gia
                            </a></li>
                          <li><a href="/bxh?type=2" rel="" class="rank_tab__item<%-type==2?'_active':''%>">
                              Top Nhiệm Vụ
                            </a></li>
                        </ul>
                      </div>
                      <div class="rank_result">
                        <ul class="rank_result__head">
                          <li>HẠNG</li>
                          <li>NHÂN VẬT</li>
                          <%if(type == 0){%>
                            <li>Sức Mạnh</li>
                            <li>Đệ tử</li>
                          <li>Tổng</li>
                            <%}else if(type==1) {%>
                              <li>Tổng số tiền</li>
                              <%} else if(type==2){%>
                                <li>Nhiệm Vụ Chính</li>
                                <li>Nhiệm Vụ Nhánh</li>
                                <%}%>
                        </ul>
                        <%var allUserData;
                        if(type==0){
                          allUserData = allUser
                        }
                        else if(type == 1){
                          allUserData = topReCharge
                        }
                        else if(type == 2){
                          allUserData = topQuest
                        }
                        %>
                        <ul class="rank_result__body">
                          <% for (let i = 0; i < allUserData.length; i++) {%>
                            <% if (i < 10) { %>
                              <li class="ranking-page page-1">
                                <span>
                                  <b class="<%= i+1 === 1 ? 'top1' : i+1 === 2 ? 'top2' : i+1 === 3 ? 'top3' : '' %>"><%= i+1 %></b>
                                </span>
                                <span class="rank__name">
                                  <b><img src="<%=options.getAvatar[allUserData[i].gender] || 'https://png.pngtree.com/png-clipart/20230823/original/pngtree-anonymous-unknown-avatar-icon-unnamed-picture-image_8241745.png'%>"><%=allUserData[i]?.name || allUserData[i]?.username%></b>
                                </span>
                                <%if(type == 0){%>
                                  <span>
                                    <b><%=shortenPower(allUserData[i].power)%></b>
                                  </span>
                                  <span>
                                    <b><%=shortenPower(allUserData[i].pet_power)%></b>
                                  </span>
                                  <span>
                                    <b><%=shortenPower(allUserData[i].power + allUserData[i].pet_power)%></b>
                                  </span>
                                  <%}%>
                                  <%if(type == 1){%>
                                    <span>
                                      <b><%=allUserData[i].tongnap%></b>
                                    </span>
                                    <%}%>
                                    <%if(type == 2){%>
                                      <span>
                                        <b><%=JSON.parse(allUserData[i].data_task)[1]%></b>
                                      </span>
                                      <span>
                                        <b><%=JSON.parse(allUserData[i].data_task)[2]%></b>
                                      </span>
                                      <%}%>
                              </li>
                            <% } %>
                          <% } %>
                          
                        </ul>
                      </div>
                    </div>
                  </div>
                </div>
            </div>
          </div>
        </div>
      </section>
      
