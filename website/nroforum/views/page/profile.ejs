<%-include("../partials/meta.ejs")%>

    <body>
        <%-include("../partials/head.ejs")%>
            <style>
                .modal {
                    display: none;
                    position: fixed;
                    z-index: 1;
                    left: 0;
                    top: 0;
                    width: 100%;
                    height: 100%;
                    overflow: auto;
                    background-color: rgba(0, 0, 0, 0.4);
                }

                .modal-content {
                    background-color: #fefefe;
                    margin: 15% auto;
                    padding: 20px;
                    border: 1px solid #888;
                    width: 70%;
                }

                .close {
                    color: red;
                    position: absolute;
                    top: 10px;
                    right: 10px;
                    font-size: 28px;
                    font-weight: bold;
                }

                .close:hover,
                .close:focus {
                    color: darkred;
                    text-decoration: none;
                    cursor: pointer;
                }

                .modal-content input[type=password] {
                    width: 100%;
                    padding: 12px 20px;
                    margin: 8px 0;
                    display: inline-block;
                    border: 1px solid #ccc;
                    border-radius: 4px;
                    box-sizing: border-box;
                }

                /* CSS cho button trong modal */
                .modal-content button {
                    background-color: #4caf50;
                    color: white;
                    padding: 14px 20px;
                    margin: 8px 0;
                    border: none;
                    border-radius: 4px;
                    cursor: pointer;
                    width: 100%;
                }

                .modal-content input[type=password]:focus {
                    outline: none;
                }

                @media only screen and (max-width: 600px) {
                    .modal-content {
                        width: 90%;
                        margin-top: 20%;
                        margin-bottom: 20%;
                    }
                }
            </style>
            <section class="mt-donwload">
                <div class="mt-4 mb-4 d-flex justify-content-center text-center">
                    <div class="title">Tải Game</div>
                </div>
                <div class="list-cta flex text-center"><a href="/assets/download/pc.rar" class="download-apk"></a> <a
                        href="https://testflight.apple.com/join/6OHPuQQZ" class="download-ios"></a> <a
                        href="/assets/download/apk.apk" class="download-and"></a></div>
            </section>
            <section class="section container section--bxh bxh scrollFrame">
                <!---->
                <article class="article content-message">
                    <div class="article__meta">
                        <div class="article__user"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512"
                                class="user-post-verry kKsfma">
                                <path
                                    d="M504 256c0 136.967-111.033 248-248 248S8 392.967 8 256 119.033 8 256 8s248 111.033 248 248zM227.314 387.314l184-184c6.248-6.248 6.248-16.379 0-22.627l-22.627-22.627c-6.248-6.249-16.379-6.249-22.628 0L216 308.118l-70.059-70.059c-6.248-6.248-16.379-6.248-22.628 0l-22.627 22.627c-6.248 6.248-6.248 16.379 0 22.627l104 104c6.249 6.249 16.379 6.249 22.628.001z">
                                </path>
                            </svg> <img src="<%=options.getAvatar[player[0].gender]%>" class="icon-profile-post"> <b>
                                <%=user[0]?.username%> - số dư: <%=user[0]?.vnd%>
                            </b></div>
                    </div>
                    <div class="article__content mt-2">
                        <div class="text-center mb-2">
                            <!---->
                            <button class="btn button mr-2 btn-main btn-sm"><svg xmlns="http://www.w3.org/2000/svg"
                                    viewBox="0 0 36 24">
                                    <path d="m18 0 8 12 10-8-4 20H4L0 4l10 8 8-12z"></path>
                                </svg>
                                Nạp số dư
                            </button>
                            <button id="activeAccount" class="btn button mr-2 btn-main btn-sm"><svg
                                    xmlns="http://www.w3.org/2000/svg" viewBox="0 0 36 24">
                                    <path d="m18 0 8 12 10-8-4 20H4L0 4l10 8 8-12z"></path>
                                </svg>
                                Mở thành viên
                            </button>
                            <button class="btn button mr-2 btn-main btn-sm" id="changePassword"><svg
                                    xmlns="http://www.w3.org/2000/svg" viewBox="0 0 36 24">
                                    <path d="m18 0 8 12 10-8-4 20H4L0 4l10 8 8-12z"></path>
                                </svg>
                                Đổi mật khẩu
                            </button> <button class="btn button mr-2 btn-main btn-sm"><svg
                                    xmlns="http://www.w3.org/2000/svg" viewBox="0 0 36 24">
                                    <path d="m18 0 8 12 10-8-4 20H4L0 4l10 8 8-12z"></path>
                                </svg>
                                Mã bảo vệ
                            </button>
                        </div>
                    </div>
                </article>
            </section>
            <!-- Modal -->
            <div id="myModal" class="modal">
                <div class="modal-content">
                    <span class="close">&times;</span>
                    <h2>Đổi mật khẩu</h2>
                    <input type="password" id="oldPassword" placeholder="Mật khẩu cũ">
                    <input type="password" id="newPassword" placeholder="Mật khẩu mới">
                    <center><button id="submitPassword">Xác nhận</button></center>
                </div>
            </div>
            <script>
                var changePasswordBtn = document.getElementById("changePassword");
                var modal = document.getElementById("myModal");
                var closeBtn = document.getElementsByClassName("close")[0];

                changePasswordBtn.onclick = function () {
                    modal.style.display = "block";
                }

                closeBtn.onclick = function () {
                    modal.style.display = "none";
                }

                window.onclick = function (event) {
                    if (event.target == modal) {
                        modal.style.display = "none";
                    }
                }
                document.getElementById("submitPassword").addEventListener("click", function () {
                    var oldPassword = document.getElementById("oldPassword").value;
                    var newPassword = document.getElementById("newPassword").value;

                    console.log("Mật khẩu cũ:", oldPassword);
                    console.log("Mật khẩu mới:", newPassword);

                    $.ajax({
                        url: "/auth/changePassword",
                        method: "POST",
                        data: { oldPassword: oldPassword, newPassword: newPassword },
                        success: function (response) {
                            if (response.error) {
                                return toastr.error(response.message, "Thất bại")
                            }
                            toastr.success(response.message, "Thành công !")
                            setTimeout(() =>{
                               window.location.href = "/login"
                           },3000)
                        },
                        error: function (error) {
                            return toastr.error('Đổi mật khẩu thất bại !', "Thất bại")
                        }
                    });
                });
                var activeBtn = document.querySelector("#activeAccount");
                activeBtn.addEventListener("click", (event) => {
                    event.preventDefault();
                    $.ajax({
                        url: "/active",
                        method: "GET",
                        success: (data, status) => {
                            if (data.error) {
                                toastr["error"](data?.message, "Error")
                            }
                            else {
                                toastr["success"](data?.message, "Success")
                            }
                        },
                        error: (data, status) => {
                            console.log(data)
                            toastr["error"](data?.message || "Đã xảy ra lỗi tại máy chủ!", "Error")
                        }
                    })
                })
            </script>

