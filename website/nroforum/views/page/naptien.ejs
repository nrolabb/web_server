      <section class="mt-donwload">
        <div class="mt-4 mb-4 d-flex justify-content-center text-center">
          <div class="title">Nạp Tiền</div>
        </div>
        <div class="list-cta flex text-center">
          <ul>
            <li id="input-tab-btn" class="active">Thẻ cào</li>
            <li id="qr-tab-btn">Ngân hàng</li>
          </ul>
        </div>
        <center>
          <div id="input-tab-content">
          <p style="font-family: Pony; color: red;">Tính năng nạp thẻ cào không ổn định, vui lòng nạp bằng atm !</p>
          <div class="col-md-6">
            <form class="form-horizontal" style="text-align: left">
              <div class="mb-3">
                <label class="font-weight-bold">Nhà mạng</label>
                <select class="form-select" id="telco">
                  <option selected="" value="VIETTEL">VIETTEL</option>
                  <option value="VINAPHONE">VINAPHONE</option>
                  <option value="MOBIFONE">MOBIFONE</option>
                  <option value="GATE">GATE</option>
                  <option value="ZING">ZING</option>
                </select>
              </div>

              <div class="mb-3">
                <label class="font-weight-bold">Mệnh giá</label>
                <select class="form-select" id="menhgia">
                </select>
              </div>

              <div class="mb-3">
                <label class="font-weight-bold">Mã thẻ</label>
                <input class="form-control" type="text" id="code" placeholder="Mã thẻ" required="">
              </div>

              <div class="mb-3">
                <label class="font-weight-bold">Mã serial</label>
                <input class="form-control" type="text" id="serial" placeholder="Mã serial" required="">
              </div>
              <div class="form-group" style="text-align: center">
                <button type="submit" id="submit" style="font-family: Pony;">
                  Nạp tiền
               </button>
              </div>
            </form>
          </div>
        </div>
        <div id="qr-tab-content" class="input-tab">
          <div class="bank-info">
            <div class="transfer-info" style="color: #9d441c;">
              <h2 style="font-family: Pony;">Thông tin chuyển khoản</h2>
              <p style="font-family: Pony;">Số tài khoản: 0280511032409</p>
              <p style="font-family: Pony;">Chủ tài khoản: NGUYEN TRONG TAN</p>
              <p style="font-family: Pony;">Ngân hàng: MB Bank</p>
              <p style="font-family: Pony;">Nội dung: dragonsuper <%=user[0].username%></p>
              <p style="font-family: Pony; color: red;">Hệ thống sẽ tự động duyệt từ 1 - 5 phút</p>
              <p style="font-family: Pony; color: red;">Nếu lâu quá chưa thấy cộng tiền, vui lòng chụp bill gửi cho admin qua zalo !</p>
              <div class="qrcode">
                <img style="height: auto; width: 100%;" src="https://api.qrserver.com/v1/create-qr-code/?data=<%=qrcontent%>&amp;size=100x100" alt="QR Code">
              </div>
            </div>
          </div>
        </div>
      </center>

      </section>

      <script>
        document.getElementById('input-tab-btn').addEventListener('click', function () {
          document.getElementById('input-tab-btn').classList.add('active');
          document.getElementById('qr-tab-btn').classList.remove('active');
          document.getElementById('input-tab-content').style.display = 'block';
          document.getElementById('qr-tab-content').style.display = 'none';
        });

        document.getElementById('qr-tab-btn').addEventListener('click', function () {
          document.getElementById('qr-tab-btn').classList.add('active');
          document.getElementById('input-tab-btn').classList.remove('active');
          document.getElementById('qr-tab-content').style.display = 'block';
          document.getElementById('input-tab-content').style.display = 'none';
        });
      </script>
  <script>
    var telco = document.querySelector("#telco");
    var menhgia = document.querySelector("#menhgia");
    var submit = document.querySelector("#submit")
    var serial = document.querySelector("#serial")
    var code = document.querySelector("#code")

    function changeMenhGia(value) {

      var optionsData = <%-JSON.stringify(dataCK)%>;
      var selectedOptionData = optionsData.filter(i => i.telco === value);

      menhgia.innerHTML = "";

      if (selectedOptionData) {
        for (let key in selectedOptionData) {
          if (selectedOptionData.hasOwnProperty(key)) {
            var option = document.createElement("option");
            option.value = selectedOptionData[key].value;
            option.text = new Intl.NumberFormat('vi-VN', {
              style: 'currency',
              currency: 'VND'
            }).format(selectedOptionData[key].value, 0);
            menhgia.appendChild(option);
          }
        }
      } else {
        console.log("Không tìm thấy thông tin cho giá trị đã chọn.");
      }
    }

    changeMenhGia(telco.value);
    telco.addEventListener("change", () => {
      changeMenhGia(telco.value);
    });
    submit.addEventListener("click", (event) => {
      event.preventDefault();
      submit.disabled = true
      submit.innerHTML = `<i class="fa fa-spinner fa-spin"></i> Vui lòng chờ ....`
      $.ajax({
        url: "/gachthe1s/guithe",
        method: "POST",
        data: {
          serial: serial.value,
          code: code.value,
          amount: menhgia.value,
          telco: telco.value
        },
        success: (data, status) => {
          toastr[`${data?.error ? 'error' : 'success'}`](data?.message, `${data?.error ? "Lỗi" : "Thành Công"}`)
          submit.disabled = false
          submit.innerHTML = `Đồng ý`
        }
      })
    })
  </script>
