          padding: 10px;
          font-size: 18px;
          font-weight: bold;
          font-family: Pony;
          margin: 0 5px;
          cursor: pointer;
        }

        .input-tab {
          display: none;
        }

        .form-select {
          padding: 10px;
          font-size: 16px;
          border-radius: 5px;
          border: none;
          background-color: #fff;
          color: #333;
          width: 100%;
          cursor: pointer;
