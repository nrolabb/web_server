<%-include("../partials/meta.ejs")%>
  <body>
    <style>
      .titleSpin{
        position: absolute;
        background: linear-gradient(135deg, #ff4d4d, #ff9933);
        font-family: Pony;
        color: white;
        font-size: 16px;
        padding: 10px 20px;
        border-radius: 8px;
        box-shadow: 0 4px 15px rgba(255, 77, 77, 0.4);
        text-shadow: 1px 1px 2px rgba(0,0,0,0.3);
      }
      .showImg {
        opacity: 1;
        z-index: 1;
        position: relative;
        transform: translateY(-165px);
        background: white;
        border-radius: 15px;
        box-shadow: rgb(175 162 138 / 38%) 1px 1px 10px 6px;
      }

      .gift-container.gift-container-x10 {
        height: min(620px, 90vh);
        padding: 42px 22px 20px;
        overflow-y: auto;
      }
      .spin-result-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        grid-template-rows: repeat(5, minmax(92px, 1fr));
        gap: 10px;
        min-height: 100%;
      }
      .spin-result-item {
        min-width: 0;
        padding: 8px 6px;
        text-align: center;
        background: rgba(255, 255, 255, 0.38);
        border: 2px solid rgba(255, 255, 255, 0.55);
        border-radius: 12px;
      }
      .spin-result-icon {
        display: block;
        width: 44px;
        height: 44px;
        margin: 0 auto 5px;
        object-fit: contain;
        filter: drop-shadow(0 2px 2px rgba(0, 0, 0, 0.25));
      }
      .spin-result-item.reward-pending .spin-result-icon,
      .spin-result-item.reward-pending .spin-result-name,
      .spin-result-item.reward-pending .spin-result-code {
        opacity: 0;
      }
      .spin-result-item.reward-revealed .spin-result-icon,
      .spin-result-item.reward-revealed .spin-result-name,
      .spin-result-item.reward-revealed .spin-result-code {
        animation: rewardCellReveal 0.28s ease-out both;
      }
      @keyframes rewardCellReveal {
        from { opacity: 0; transform: scale(0.55); }
        to { opacity: 1; transform: scale(1); }
      }
      .flying-reward-ball {
        position: fixed;
        z-index: 2147483647;
        width: 52px;
        height: 52px;
        pointer-events: none;
        border-radius: 50%;
        background: radial-gradient(circle at 34% 30%, #fff, #ffe23e 36%, #ff9800 72%, #e65100);
        box-shadow: 0 0 18px 7px rgba(255, 226, 62, 0.68), inset 0 -7px 13px rgba(0, 0, 0, 0.2);
        transform: translate(-50%, -50%) scale(0.45);
      }
      .spin-result-name {
        min-height: 30px;
        color: #fff;
        font-family: Pony, sans-serif;
        font-size: 12px;
        line-height: 15px;
        text-shadow: 1px 1px 2px rgba(0, 0, 0, 0.45);
        overflow-wrap: anywhere;
      }
      .spin-result-code {
        margin-top: 5px;
        padding: 3px 5px;
        overflow: hidden;
        color: #6c5ce7;
        background: #fff;
        border-radius: 5px;
        font-family: monospace;
        font-size: 11px;
        text-overflow: ellipsis;
        white-space: nowrap;
      }
      @media only screen and (max-width: 480px) {
        .gift-container.gift-container-x10 {
          width: 95vw;
          zoom: 1 !important;
          padding-right: 12px;
          padding-left: 12px;
        }
      }

      /* Page title */
      .spin-page-title {
        text-align: center;
        padding: 20px 0 10px;
        font-family: Pony, sans-serif;
      }
      .spin-page-title h1 {
        font-size: 32px;
        background: linear-gradient(135deg, #ff6b35, #f7c948, #ff6b35);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        text-shadow: none;
        filter: drop-shadow(2px 2px 4px rgba(0,0,0,0.2));
        margin: 0;
        letter-spacing: 2px;
      }
      .spin-page-title .balance-info {
        font-size: 15px;
        color: #555;
        margin-top: 5px;
        font-family: sans-serif;
      }
      .spin-page-title .balance-info span {
        color: #ff4d4d;
        font-weight: bold;
      }

      /* Spin History Panel */
      .spin-history-panel {
        max-width: 800px;
        margin: 20px auto 30px;
        padding: 0 15px;
      }
      .spin-history-panel .panel-header {
        background: linear-gradient(135deg, #1a1a2e, #16213e);
        color: #fff;
        padding: 14px 20px;
        border-radius: 12px 12px 0 0;
        font-family: Pony, sans-serif;
        font-size: 18px;
        display: flex;
        align-items: center;
        gap: 10px;
      }
      .spin-history-panel .panel-header .icon-history {
        font-size: 22px;
      }
      .spin-history-panel .panel-body {
        background: rgba(255, 255, 255, 0.95);
        border: 1px solid #e0e0e0;
        border-top: none;
        border-radius: 0 0 12px 12px;
        max-height: 350px;
        overflow-y: auto;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
      }
      .spin-history-panel .panel-body::-webkit-scrollbar {
        width: 6px;
      }
      .spin-history-panel .panel-body::-webkit-scrollbar-track {
        background: #f1f1f1;
        border-radius: 3px;
      }
      .spin-history-panel .panel-body::-webkit-scrollbar-thumb {
        background: linear-gradient(135deg, #ff6b35, #f7c948);
        border-radius: 3px;
      }
      .history-table {
        width: 100%;
        border-collapse: collapse;
        font-family: sans-serif;
        font-size: 14px;
      }
      .history-table thead {
        position: sticky;
        top: 0;
        z-index: 2;
      }
      .history-table thead th {
        background: linear-gradient(135deg, #2d3436, #636e72);
        color: #fff;
        padding: 12px 15px;
        text-align: left;
        font-weight: 600;
        font-size: 13px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
      }
      .history-table tbody tr {
        transition: background-color 0.2s ease;
        border-bottom: 1px solid #f0f0f0;
      }
      .history-table tbody tr:hover {
        background-color: #fff8f0;
      }
      .history-table tbody tr:nth-child(even) {
        background-color: #fafafa;
      }
      .history-table tbody tr:nth-child(even):hover {
        background-color: #fff8f0;
      }
      .history-table tbody td {
        padding: 10px 15px;
        color: #333;
      }
      .history-table .player-name {
        font-weight: 600;
        color: #2d3436;
      }
      .history-table .item-name {
        color: #e17055;
        font-weight: 500;
      }
      .history-table .item-time {
        color: #636e72;
        font-size: 13px;
      }
      .history-table .item-code {
        font-family: monospace;
        background: #f0f0f0;
        padding: 3px 8px;
        border-radius: 4px;
        font-size: 12px;
        color: #6c5ce7;
      }
      .empty-history {
        text-align: center;
        padding: 40px 20px;
        color: #999;
        font-style: italic;
      }
      .empty-history .icon-empty {
        font-size: 40px;
        margin-bottom: 10px;
      }

      /* New spin highlight animation */
      @keyframes newSpinHighlight {
        0% { background-color: #fff3cd; transform: scale(1.01); }
        100% { background-color: transparent; transform: scale(1); }
      }
      .history-table tbody tr.new-spin {
        animation: newSpinHighlight 2s ease forwards;
      }

      /* Cost info badges */
      .spin-cost-info {
        text-align: center;
        margin: 10px 0 0;
        display: flex;
        justify-content: center;
        gap: 15px;
        flex-wrap: wrap;
      }
      .cost-badge {
        background: rgba(0,0,0,0.05);
        padding: 6px 16px;
        border-radius: 20px;
        font-size: 13px;
        font-family: sans-serif;
        color: #555;
      }
      .cost-badge strong {
        color: #e17055;
      }

      /* === Machine Reward: Bay từ lỗ ra bóng, phóng to trên mặt máy === */
      .machine-reward {
        position: absolute;
        z-index: 7;
        pointer-events: none;
      }
      .machine-reward-ball {
        position: absolute;
        left: 50%;
        top: 50%;
        width: 70px;
        height: 70px;
        border-radius: 50%;
        background: radial-gradient(circle at 35% 35%, #fffbe8, #ffe23e 40%, #ff9800 80%, #e65100);
        box-shadow: 0 0 20px 8px rgba(255, 226, 62, 0.6), inset 0 -8px 18px rgba(0,0,0,0.2), inset 0 4px 12px rgba(255,255,255,0.5);
        transform: translate(-50%, -50%) scale(1);
        opacity: 1;
      }
      .machine-reward-ball::after {
        content: '';
        position: absolute;
        top: 12%;
        left: 22%;
        width: 35%;
        height: 25%;
        background: radial-gradient(ellipse, rgba(255,255,255,0.9), transparent);
        border-radius: 50%;
        transform: rotate(-15deg);
      }
      .machine-reward-icon {
        position: absolute;
        left: 50%;
        top: 50%;
        width: 120px;
        height: 120px;
        object-fit: contain;
        opacity: 0;
        transform: translate(-50%, -50%) scale(0);
        filter: drop-shadow(0 0 15px #fff) drop-shadow(0 0 30px #ffe23e) drop-shadow(0 0 50px rgba(255,150,0,0.5));
        z-index: 2;
      }
      .machine-reward-name {
        position: absolute;
        left: 50%;
        width: 330px;
        color: #fff;
        font: 700 25px Pony, sans-serif;
        text-align: center;
        text-shadow: 0 3px 4px #142359, 0 0 10px #246dff, 0 0 20px rgba(36,109,255,0.5);
        opacity: 0;
        transform: translateX(-50%);
        z-index: 3;
      }
      /* Sparkle tia sáng */
      .machine-reward-sparkles {
        position: absolute;
        left: 50%;
        top: 50%;
        width: 0;
        height: 0;
        z-index: 1;
        pointer-events: none;
      }
      .machine-reward-sparkle {
        position: absolute;
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: #ffe23e;
        box-shadow: 0 0 8px 2px #ffe23e;
        opacity: 0;
      }
    </style>
    <%-include("../partials/head.ejs")%>

      <!-- Page Title -->
      <div class="spin-page-title">
        <h1>🎰 Vòng Quay May Mắn 🎰</h1>
        <div class="balance-info">Số dư hiện tại: <span id="currentBalance"><%= user[0]?.vnd || 0 %></span> VNĐ</div>
        <div class="spin-cost-info">
          <div class="cost-badge">Quay 1 lần: <strong>1,000 VNĐ</strong></div>
          <div class="cost-badge">Quay 10 lần: <strong>9,000 VNĐ</strong></div>
        </div>
      </div>

      <section class="section section game_rotation">
        <div class="section__content_rotation">
          <div class="inner_rotation inner--game_rotation">
            <div class="airblowing">
              <div id="anireward" class="anireward">
                <div class="anireward__item anireward__item--1"><img
                    src="../assets/images/spin/MxrStMQ.png"></div>
                <div class="anireward__item anireward__item--2"><img
                    src="../assets/images/spin/cFbZyHg.png"></div>
                <div class="anireward__item anireward__item--3"><img
                    src="../assets/images/spin/J6Q30Tz.png"></div>
                <div class="anireward__item anireward__item--4"><img
                    src="../assets/images/spin/byPkOwR.png"></div>
                <div class="anireward__item anireward__item--5"><img
                    src="../assets/images/spin/02YbcFI.png"></div>
                <div class="anireward__item anireward__item--6"><img
                    src="../assets/images/spin/SaQYFBU.png"></div>
                <div class="anireward__item anireward__item--7"><img
                    src="../assets/images/spin/ZwxlZQw.png"></div>
                <div class="anireward__item anireward__item--8"><img
                    src="../assets/images/spin/tdEvIFz.png"></div>
                <div class="anireward__item anireward__item--9"><img
                    src="../assets/images/spin/Wch0Xo8.png"></div>
                <div class="anireward__item anireward__item--10"><img
                    src="../assets/images/spin/l3fr7CW.png"></div>
                <div class="anireward__item anireward__item--11"><img
                    src="../assets/images/spin/NtTiHP8.png"></div>
                <div class="anireward__item anireward__item--12"><img
                    src="../assets/images/spin/55EQLjI.png"></div>
                <div class="anireward__item anireward__item--13"><img
                    src="../assets/images/spin/tXexoPJ.png"></div>
                <div class="anireward__item anireward__item--14"><img
                    src="../assets/images/spin/QbufFVD.png"></div>
                <div class="anireward__item anireward__item--15"><img
                    src="../assets/images/spin/cGEiQkq.png"></div>
              </div>
              <div id="action" class="action"><a href="javascript:;"
                  class="action__open action__open--1 pm__rut rut-1"><img
                    src="../assets/images/spin/btn.png" class="action__btn"></a> <a
                  href="javascript:;" class="action__open action__open--10 pm__rut rut-10"><img
                    src="../assets/images/spin/btn.png" class="action__btn"></a></div>
              <div id="machineReward" class="machine-reward" aria-hidden="true">
                <div class="machine-reward-ball"></div>
                <div class="machine-reward-sparkles"></div>
                <img class="machine-reward-icon" alt="Phần thưởng">
                <div class="machine-reward-name"></div>
              </div>
            </div>
          </div>
        </div>
        <div class="spinModal">
        </div>

      </section>

      <!-- Spin History Panel -->
      <section class="spin-history-panel">
        <div class="panel-header">
          <span class="icon-history">📜</span>
          Lịch Sử Quay Thưởng
        </div>
        <div class="panel-body">
          <table class="history-table">
            <thead>
              <tr>
                <th style="width: 5%">#</th>
                <th style="width: 25%">Người chơi</th>
                <th style="width: 35%">Vật phẩm</th>
                <th style="width: 15%">Mã GiftCode</th>
                <th style="width: 20%">Thời gian</th>
              </tr>
            </thead>
            <tbody id="spinHistoryBody">
              <% const history = typeof spinHistory !== 'undefined' && Array.isArray(spinHistory) ? spinHistory : []; %>
              <% if (history.length > 0) { %>
                <% history.forEach(function(record, index) { %>
                  <tr>
                    <td><%= index + 1 %></td>
                    <td class="player-name"><%= record.username || 'N/A' %></td>
                    <td class="item-name"><%= record.name %></td>
                    <td><span class="item-code"><%= record.code %></span></td>
                    <td class="item-time"><%= new Date(Number(record.time_stamps)).toLocaleString('vi-VN', { timeZone: 'Asia/Ho_Chi_Minh' }) %></td>
                  </tr>
                <% }); %>
              <% } else { %>
                <tr>
                  <td colspan="5" class="empty-history">
                    <div class="icon-empty">🎲</div>
                    Chưa có lịch sử quay nào!
                  </td>
                </tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </section>

      <script>
       var rut1 = document.querySelector(".rut-1");
          var rut10 = document.querySelector(".rut-10");
          var isSpinning = false;

          const addAndRemoveClass = (element, className, timeout) => {
            element.classList.add(className);
            setTimeout(() => {
              element.classList.remove(className);
            }, timeout);
          };

          rut10.addEventListener("click", () => {
            if (isSpinning) return;
            handleButtonClick("x10");
          });

          rut1.addEventListener("click", () => {
            if (isSpinning) return;
            handleButtonClick("x1");
          });

          function handleButtonClick(type) {
            isSpinning = true;
            var anireward__item = document.querySelectorAll(".anireward__item");
            anireward__item.forEach(async(item, index) => {
              addAndRemoveClass(item, `anireward__running--${index + 1}`, 5000);
            });
            setTimeout(() => {
              $.ajax({
              method: "POST",
              url: "/spin",
              data: JSON.stringify({ type: type }),
              headers:{
                'Content-type': 'application/json; charset=UTF-8'
              },
              success: async (data, status) => {
                       if(data.error){
                           isSpinning = false;
                           toastr["error"](data?.message, "Error")
                       }
                       else {
                        console.log(data);
                        // Update balance display
                        if (data.newBalance !== undefined) {
                          document.getElementById("currentBalance").textContent = data.newBalance;
                        }

                        // Show result modal
                        var spinModal = document.querySelector(".spinModal");
                        if (type === "x10" && data.data.length > 1) {
                          // Show multiple items for x10
                          var itemsHtml = data.data.map((item, i) => `
                            <div class="spin-result-item reward-pending" data-reward-index="${i}">
                              <img class="spin-result-icon" src="${item.img}" alt="${item.name}">
                              <div class="spin-result-name">${item.name}</div>
                              <div class="spin-result-code">${data.giftCodes[i]}</div>
                            </div>
                          `).join('');
                          spinModal.innerHTML = `
                          <div class="gift-container gift-container-x10"><button type="button" class="btn btn-primary btn-close-gift">
                            X
                          </button>
                          <div class="spin-result-grid">
                            ${itemsHtml}
                          </div>
                          </div>
                          <div class="gift-background"></div>
                          `;
                        } else {
                          spinModal.innerHTML = `
                          <div class="gift-container"><button type="button" class="btn btn-primary btn-close-gift">
                            X
                          </button>
                          <div class="row justify-content-end">
                            <div class="col-12 mt-5 d-flex justify-content-center">
                              <div class="titleSpin">${data.data[0].name}</div>
                                <img style="height: auto; width: 50%; top: 100%" src="${data.data[0].img}" class="img showImg">
                              <div class="message-success message-show">
                                <b>${data.giftCodes[0]}</b>
                                </div>
                            </div>
                          </div>
                          </div>
                          <div class="gift-background"></div>
                          `;
                        }
                        await playRewardReveal(data.data);
                        document.querySelector(".btn-close-gift").addEventListener("click", () => {
                          document.querySelector(".spinModal").innerHTML = ``;
                        });

                        // Add new entries to history table
                        addToHistory(data);
                        isSpinning = false;
                       }
                   },
                   error: (data, status) => {
                       isSpinning = false;
                       toastr["error"](data?.message || "Đã xảy ra lỗi tại máy chủ!", "Error")
                   }
            })
            }, 5000)
          }

          function playRewardReveal(items) {
            if (items.length > 1) {
              return playMultiRewardReveal(items);
            }
            var reveal = document.getElementById("machineReward");
            var machine = document.querySelector(".airblowing");
            var icon = reveal.querySelector(".machine-reward-icon");
            var ball = reveal.querySelector(".machine-reward-ball");
            var sparklesContainer = reveal.querySelector(".machine-reward-sparkles");
            var name = reveal.querySelector(".machine-reward-name");
            var isFast = items.length > 1;
            var revealDuration = isFast ? 1500 : 3200;

            return items.reduce(function(sequence, item) {
              return sequence.then(function() {
                return new Promise(function(resolve) {
                  var rect = machine.getBoundingClientRect();
                  // Vị trí lỗ bóng ra (dưới máy)
                  var startX = rect.left + rect.width * (197 / 648);
                  var startY = rect.top + rect.height * (730 / 869);
                  // Vị trí giữa mặt máy
                  var endX = rect.left + rect.width * (324 / 648);
                  var endY = rect.top + rect.height * (335 / 869);
                  var ballSize = Math.max(45, rect.width * (70 / 648));
                  var iconSize = Math.max(70, rect.width * (120 / 648));

                  // Chuẩn bị ảnh item
                  icon.src = item.img;
                  icon.alt = item.name;
                  name.textContent = item.name;

                  // Reset trạng thái
                  document.body.appendChild(reveal);
                  reveal.className = "machine-reward";
                  reveal.style.position = "fixed";
                  reveal.style.zIndex = "2147483647";
                  reveal.style.display = "block";
                  reveal.style.width = "1px";
                  reveal.style.height = "1px";
                  reveal.setAttribute("aria-hidden", "false");

                  // Đặt kích thước bóng
                  ball.style.width = ballSize + "px";
                  ball.style.height = ballSize + "px";
                  ball.style.display = "block";
                  ball.style.opacity = "1";

                  // Đặt kích thước icon
                  icon.style.width = iconSize + "px";
                  icon.style.height = iconSize + "px";
                  icon.style.opacity = "0";

                  // Vị trí tên item (dưới icon)
                  name.style.top = (iconSize * 0.7 + 20) + "px";

                  // Tạo sparkles (tia sáng)
                  sparklesContainer.innerHTML = '';
                  for (var s = 0; s < 12; s++) {
                    var sp = document.createElement('div');
                    sp.className = 'machine-reward-sparkle';
                    sparklesContainer.appendChild(sp);
                  }
                  var sparkles = sparklesContainer.querySelectorAll('.machine-reward-sparkle');

                  // === PHASE 1: Bóng bay từ lỗ lên giữa mặt máy (0% -> 45%) ===
                  var phase1End = 0.45;
                  // === PHASE 2: Bóng nổ, icon xuất hiện phóng to (45% -> 75%) ===
                  var phase2End = 0.75;
                  // === PHASE 3: Icon + tên hiện rõ rồi fade out (75% -> 100%) ===

                  // Animation cho container (vị trí di chuyển)
                  reveal.animate([
                    { left: startX + "px", top: startY + "px", offset: 0 },
                    { left: startX + "px", top: (startY - rect.height * 0.04) + "px", offset: 0.12 },
                    { left: endX + "px", top: endY + "px", offset: phase1End },
                    { left: endX + "px", top: endY + "px", offset: 1 }
                  ], { duration: revealDuration, easing: "ease-in-out", fill: "forwards" });

                  // Animation cho bóng: nhỏ -> to -> nổ tung
                  ball.animate([
                    { transform: "translate(-50%, -50%) scale(0.3)", opacity: 1, boxShadow: "0 0 10px 4px rgba(255,226,62,0.4)", offset: 0 },
                    { transform: "translate(-50%, -50%) scale(0.6)", opacity: 1, boxShadow: "0 0 15px 6px rgba(255,226,62,0.5)", offset: 0.12 },
                    { transform: "translate(-50%, -50%) scale(1)", opacity: 1, boxShadow: "0 0 25px 10px rgba(255,226,62,0.7)", offset: phase1End },
                    { transform: "translate(-50%, -50%) scale(1.1)", opacity: 1, boxShadow: "0 0 30px 15px rgba(255,226,62,0.8)", offset: phase1End + 0.04 },
                    { transform: "translate(-50%, -50%) scale(2.5)", opacity: 0, boxShadow: "0 0 60px 30px rgba(255,226,62,0)", offset: phase2End - 0.05 },
                    { transform: "translate(-50%, -50%) scale(3)", opacity: 0, offset: 1 }
                  ], { duration: revealDuration, easing: "ease-out", fill: "forwards" });

                  // Animation cho icon: ẩn trong bóng -> xuất hiện phóng to
                  icon.animate([
                    { opacity: 0, transform: "translate(-50%, -50%) scale(0)", offset: 0 },
                    { opacity: 0, transform: "translate(-50%, -50%) scale(0)", offset: phase1End },
                    { opacity: 1, transform: "translate(-50%, -50%) scale(1.6)", filter: "drop-shadow(0 0 20px #fff) drop-shadow(0 0 40px #ffe23e) brightness(1.3)", offset: phase1End + 0.12 },
                    { opacity: 1, transform: "translate(-50%, -50%) scale(1.3)", filter: "drop-shadow(0 0 15px #fff) drop-shadow(0 0 30px #ffe23e) brightness(1.1)", offset: phase2End },
                    { opacity: 1, transform: "translate(-50%, -50%) scale(1.35)", filter: "drop-shadow(0 0 15px #fff) drop-shadow(0 0 30px #ffe23e) brightness(1.05)", offset: 0.88 },
                    { opacity: 0, transform: "translate(-50%, -50%) scale(1.8)", filter: "drop-shadow(0 0 10px #fff) drop-shadow(0 0 20px #ffe23e) brightness(1)", offset: 1 }
                  ], { duration: revealDuration, easing: "ease-out", fill: "forwards" });

                  // Animation cho tên item
                  name.animate([
                    { opacity: 0, transform: "translateX(-50%) translateY(15px)", offset: 0 },
                    { opacity: 0, transform: "translateX(-50%) translateY(15px)", offset: phase2End - 0.02 },
                    { opacity: 1, transform: "translateX(-50%) translateY(0)", offset: phase2End + 0.08 },
                    { opacity: 1, transform: "translateX(-50%) translateY(0)", offset: 0.90 },
                    { opacity: 0, transform: "translateX(-50%) translateY(-10px)", offset: 1 }
                  ], { duration: revealDuration, easing: "ease-out", fill: "forwards" });

                  // Animation cho sparkles (tia sáng bắn ra khi bóng nổ)
                  sparkles.forEach(function(sp, i) {
                    var angle = (i / sparkles.length) * 360;
                    var rad = angle * Math.PI / 180;
                    var dist = 50 + Math.random() * 40;
                    var tx = Math.cos(rad) * dist;
                    var ty = Math.sin(rad) * dist;
                    var sparkDelay = revealDuration * phase1End;
                    var sparkDur = revealDuration * 0.25;
                    sp.animate([
                      { opacity: 0, transform: "translate(0, 0) scale(0.5)", offset: 0 },
                      { opacity: 1, transform: "translate(" + (tx * 0.5) + "px, " + (ty * 0.5) + "px) scale(1.2)", offset: 0.3 },
                      { opacity: 0, transform: "translate(" + tx + "px, " + ty + "px) scale(0)", offset: 1 }
                    ], { duration: sparkDur, delay: sparkDelay, easing: "ease-out", fill: "forwards" });
                  });

                  setTimeout(function() {
                    // Cleanup tất cả animations
                    reveal.getAnimations().forEach(function(a) { a.cancel(); });
                    reveal.querySelectorAll("*").forEach(function(el) {
                      el.getAnimations().forEach(function(a) { a.cancel(); });
                    });
                    reveal.style.display = "none";
                    reveal.setAttribute("aria-hidden", "true");
                    sparklesContainer.innerHTML = '';
                    resolve();
                  }, revealDuration + 50);
                });
              });
            }, Promise.resolve());
          }

          function playMultiRewardReveal(items) {
            var machine = document.querySelector(".airblowing");
            var targets = Array.from(document.querySelectorAll(".spin-result-item[data-reward-index]"));
            if (!machine || targets.length !== items.length) return Promise.resolve();

            var machineRect = machine.getBoundingClientRect();
            var startX = machineRect.left + machineRect.width * (197 / 648);
            var startY = machineRect.top + machineRect.height * (730 / 869);
            var elapsedDelay = 0;
            var finishTimes = [];

            targets.forEach(function(target, index) {
              var targetRect = target.getBoundingClientRect();
              var endX = targetRect.left + targetRect.width / 2;
              var endY = targetRect.top + targetRect.height / 2;
              var ball = document.createElement("div");
              var duration = Math.max(320, 680 - index * 32);
              var gapToNext = Math.max(90, 300 - index * 23);

              ball.className = "flying-reward-ball";
              ball.style.left = startX + "px";
              ball.style.top = startY + "px";
              document.body.appendChild(ball);

              setTimeout(function() {
                var lift = Math.max(70, Math.abs(startY - endY) * 0.22);
                var flight = ball.animate([
                  { left: startX + "px", top: startY + "px", transform: "translate(-50%, -50%) scale(0.35)", opacity: 1 },
                  { left: (startX + endX) / 2 + "px", top: (Math.min(startY, endY) - lift) + "px", transform: "translate(-50%, -50%) scale(0.85)", opacity: 1, offset: 0.52 },
                  { left: endX + "px", top: endY + "px", transform: "translate(-50%, -50%) scale(1)", opacity: 1, offset: 0.86 },
                  { left: endX + "px", top: endY + "px", transform: "translate(-50%, -50%) scale(1.8)", opacity: 0 }
                ], {
                  duration: duration,
                  easing: "cubic-bezier(.2,.72,.32,1)",
                  fill: "forwards"
                });

                flight.finished.then(function() {
                  ball.remove();
                  target.classList.remove("reward-pending");
                  target.classList.add("reward-revealed");
                });
              }, elapsedDelay);

              finishTimes.push(elapsedDelay + duration);
              elapsedDelay += gapToNext;
            });

            return new Promise(function(resolve) {
              setTimeout(resolve, Math.max.apply(null, finishTimes) + 350);
            });
          }

          function addToHistory(data) {
            var tbody = document.getElementById("spinHistoryBody");
            // Remove empty state row if present
            var emptyRow = tbody.querySelector(".empty-history");
            if (emptyRow) {
              emptyRow.closest("tr").remove();
            }

            var currentUsername = "<%= user[0]?.username || 'N/A' %>";
            var existingRows = tbody.querySelectorAll("tr");
            var startIndex = existingRows.length;

            for (var i = 0; i < data.data.length; i++) {
              var now = new Date();
              var timeStr = now.toLocaleString('vi-VN', { timeZone: 'Asia/Ho_Chi_Minh' });
              var newRow = document.createElement("tr");
              newRow.classList.add("new-spin");
              newRow.innerHTML = `
                <td>${startIndex + i + 1}</td>
                <td class="player-name">${currentUsername}</td>
                <td class="item-name">${data.data[i].name}</td>
                <td><span class="item-code">${data.giftCodes[i]}</span></td>
                <td class="item-time">${timeStr}</td>
              `;
              // Insert at the beginning (newest first would be prepend, but matching server order = append)
              tbody.insertBefore(newRow, tbody.firstChild);
            }

            // Re-number rows
            var allRows = tbody.querySelectorAll("tr");
            allRows.forEach(function(row, idx) {
              var firstTd = row.querySelector("td:first-child");
              if (firstTd && !firstTd.classList.contains("empty-history")) {
                firstTd.textContent = idx + 1;
              }
            });
          }
      </script>
