<div>
  <header class="fixed-top">
    <nav class="navbar navbar-expand-md navbar-dark bg-dark">
      <div class="container"><a href="/" aria-current="page"
          class="app-icon-mb router-link-exact-active router-link-active"><img
            src="https://www.ngocrongbeo.com/image/icon1.png" class="logo-game"></a> <button type="button"
          data-toggle="collapse" data-target="#navbarHeader" aria-controls="navbarHeader" aria-expanded="false"
          aria-label="Toggle navigation" class="navbar-toggler"><span class="navbar-toggler-icon"></span></button>
        <div id="navbarHeader" class="collapse navbar-collapse">
          <ul class="navbar-nav ml-auto pl-lg-5 pl-0">
            <li class="nav-item"><a href="/" aria-current="page"
                class="nav-link router-link-exact-active router-link-active <%=options.req.url == "/" ? "active" : ""%>">
                <span class="text-upcase">
                  Trang chủ
                </span></a></li>
   <li class="nav-item"><a href="/spin" class="nav-link <%=options.req.url == "/spin" ? 
         "active" : ""%>"><span class="text-upcase">
                  Vòng quay
                </span></a></li>
            <li class="nav-item"><a href="/bxh" class="nav-link <%=options.req.url == "/bxh" ? "active" : ""%>"><span class="text-upcase">
                  BẢNG XH
                </span></a></li>
                <li class="nav-item"><a href="/naptien" class="nav-link <%=options.req.url == "/naptien" ? "active" : ""%>"><span class="text-upcase">
                  NẠP TIỀN
                </span></a></li>
                <%if(!user[0]?.username){%>
            <li class="nav-item"><a href="/login" class="nav-link <%=options.req.url == "/login" ? "active" : ""%>"><span class="text-upcase">
                  Đăng nhập
                </span></a></li>
                <%}%>
          </ul>
          <ul class="navbar-nav ml-auto">
            <%if(user[0]?.username){%>
              <li class="nav-item dropdown show_user">
                <a href="javascript:;" id="dropdown04" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false"
                  class="nav-link dropdown-toggle" style="font-family: Pony;">
                  <%=(user[0]?.username)%> - Số dư: <%=user[0]?.vnd%>
                </a>
                <div aria-labelledby="dropdown04" class="dropdown-menu text-center dropdown-menu-right not-show"><a
                    href="/profile" class="dropdown-item"><span class="text-upcase">Trang cá nhân</span></a> <a
                    href="/history" class="dropdown-item"><span class="text-upcase">Lịch sử giao dịch</span></a> <a
                    href="javascript:;" class="dropdown-item"><span class="text-upcase">Gift Code</span></a> <a
                    href="javascript:;" class="dropdown-item"><span class="text-upcase">Nạp thẻ</span></a>
                  <div class="dropdown-divider"></div> <a href="/logout" class="dropdown-item"><span
                      class="text-upcase">Đăng xuất</span></a>
                </div>
              </li>
              <script>
                var dropdown04 = document.querySelector(".show_user");
                if (dropdown04) {
                  dropdown04.addEventListener("click", async (event) => {
                    var dropdownMenu = document.querySelector(".dropdown-menu");
                    if (Array.from(dropdownMenu.classList).includes("not-show")) {
                      await dropdownMenu.classList.remove("not-show")
                    }
                    else {
                      await dropdownMenu.classList.add("not-show")
                    }
                  })
                }
              </script>
              <%}%>
          </ul>
        </div>
      </div>
    </nav>
  </header> <!---->
</div>